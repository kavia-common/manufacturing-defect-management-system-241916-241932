# Defect Management Backend (.env.example)
# Ask the orchestrator/user to set these in the real .env (do not commit secrets).

# --- Database (required) ---
# Recommended: explicitly set DATABASE_URL.
# For local/dev, the backend also attempts to infer this from the database container's
# defect_management_database/db_connection.txt (if present in a sibling workspace).
DATABASE_URL=postgresql+psycopg://appuser:dbuser123@localhost:5000/myapp

# --- Supabase (required for real authentication) ---
# For step 04.01 you can use placeholders to boot the backend; auth-protected endpoints
# will not work until real credentials exist (unless AUTH_DISABLED=true for local demos).
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_KEY=placeholder-anon-key

# --- CORS (recommended) ---
# Comma-separated list. Use "*" only for local/dev.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Authorization,Content-Type

# Optional
CORS_MAX_AGE=600
TRUST_PROXY=false

# DEV ONLY: bypass JWT verification and RBAC checks (never enable in production)
AUTH_DISABLED=false
