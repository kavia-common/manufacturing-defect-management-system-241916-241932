# Defect Management Backend (.env.example)
# Ask the orchestrator/user to set these in the real .env (do not commit secrets).
#
# NOTE: This file contains "safe to commit" example values. The Supabase anon key is
# a "publishable" client key; still treat it as config, not a secret.

# --- Database (required) ---
# Recommended: explicitly set DATABASE_URL.
# For local/dev, the backend also attempts to infer this from the database container's
# defect_management_database/db_connection.txt (if present in a sibling workspace).
DATABASE_URL=postgresql+psycopg://appuser:dbuser123@localhost:5000/myapp

# --- Supabase (required for real authentication) ---
# These values must match your Supabase project settings.
# Project URL:
SUPABASE_URL=https://fdxlxsldusunyltneupg.supabase.co
# Client "anon" key (public/publishable; used by frontend; backend uses it only to compute issuer/JWKS URLs):
SUPABASE_KEY=sb_publishable_2X2VTfNHNZSugkScYcAzBg_NlLjo_VT

# --- CORS (recommended) ---
# Comma-separated list. Use "*" only for local/dev.
# Include your frontend origin(s) so the browser can call the API with Authorization headers.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=Authorization,Content-Type

# Optional
CORS_MAX_AGE=600
TRUST_PROXY=false

# DEV ONLY: bypass JWT verification and RBAC checks (never enable in production)
AUTH_DISABLED=false
